# Copy to .env and fill in real values

# PostgreSQL
PG_DSN=postgresql://postgres:postgres@localhost:5432/langgraph

# SQL Server
MSSQL_CONN_STR=DRIVER={ODBC Driver 18 for SQL Server};SERVER=localhost;DATABASE=langgraph;UID=sa;PWD=SqlPass123!;Encrypt=yes;TrustServerCertificate=yes;

# Test database (for pytest)
MSSQL_TEST_CONN_STR=DRIVER={ODBC Driver 18 for SQL Server};SERVER=localhost;DATABASE=langgraph_test;UID=sa;PWD=SqlPass123!;Encrypt=yes;TrustServerCertificate=yes;
